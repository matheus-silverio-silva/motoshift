# ===============================
# FLUTTER / DART
# ===============================
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/
**/pubspec.lock
**/android/.gradle/
**/android/local.properties
**/android/app/google-services.json
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/*.class
.flutter-plugins
.flutter-plugins-dependencies

# ===============================
# SPRING BOOT / JAVA / MAVEN
# ===============================
**/target/
**/*.class
**/*.jar
**/*.war
**/*.ear
**/*.logs
**/hs_err_pid*
**/.mvn/wrapper/maven-wrapper.jar
**/mvnw
**/gradlew

# Arquivos de ambiente com credenciais reais
**/*.env
**/.env
**/*.env.local
**/secrets.properties

# application.properties e application-prod.properties são seguros para commitar:
# não contêm credenciais hardcoded (usam ${ENV_VAR}) e precisam estar no JAR para o Railway.
# Apenas arquivos com sufixo .local ou .secret devem ser ignorados:
**/application-*.local.properties
**/application-*.secret.properties

# Manter templates
!**/application.properties.example
!**/application.yml.example

