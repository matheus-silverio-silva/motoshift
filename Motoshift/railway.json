{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "flutter pub get && flutter build web --dart-define=API_URL=$API_URL --release",
    "watchPatterns": ["lib/**", "pubspec.yaml"]
  },
  "deploy": {
    "startCommand": "python3 -m http.server $PORT --directory build/web",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
